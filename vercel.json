{
  "buildCommand": "pnpm install && pnpm run build:css",
  "builds": [
    {
      "src": "acortador/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/public/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "acortador/wsgi.py"
    }
  ]
}
